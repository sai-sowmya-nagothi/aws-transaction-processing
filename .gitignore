# Terraform local working directory
**/.terraform/*
 
# Terraform state files
*.tfstate
*.tfstate.*
 
# Terraform plan files
*.tfplan
 
# Terraform crash logs
crash.log
crash.*.log
 
# Local variable files that may contain secrets
*.tfvars
*.tfvars.json
 
# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
 
# OS/editor files
.DS_Store
*.swp
 
 
# Terraform generated files
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.tfstate.lock.info
 
# Generated Lambda packages
*.zip
 
# Backup and temporary files
*.backup
*.before-step-functions
plan*.txt
 
# Generated reports
transaction-execution-report.csv
__pycache__/
*.pyc
