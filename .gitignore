# Terraform local working directory
**/.terraform/*
 
# Terraform state files
*.tfstate
*.tfstate.*
 
# Terraform plan files
*.tfplan
 
# Terraform crash logs
crash.log
crash.*.log
 
# Local variable files that may contain secrets
*.tfvars
*.tfvars.json
 
# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
 
# OS/editor files
.DS_Store
*.swp
 
